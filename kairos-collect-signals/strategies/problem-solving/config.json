{
  "name": "problem-solving",
  "output_mode": "topic_card",
  "tension_types": [
    "failure",
    "unexpected_behavior",
    "scaling_issue",
    "tradeoff"
  ],
  "tension_filter": {
    "required": true,
    "min_strength": 0.6
  },
  "filters": {
    "require_problem": true,
    "reject_no_failure": true
  },
  "preferences": {
    "prefer_failure": true,
    "prefer_tradeoff": true,
    "prefer_debugging": true,
    "prefer_system_breakdown": true,
    "avoid_pure_theory": true
  }
}
