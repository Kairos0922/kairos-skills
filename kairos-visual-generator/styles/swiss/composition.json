      "structure": "base → layers → side-annotations"
    },
    {
      "id": "S07",
      "name": "Annotated Field",
      "description": "开放场/地图 + 4-6标注区域 + 每区域短标签",
      "suitable_for": ["infographic"],
      "structure": "field → annotated-regions → labels"
    },
    {
      "id": "S08",
      "name": "Evidence Ladder",
      "description": "顶部论点 + 3-5证据带 + 每带事实+启示 + 结论",
      "suitable_for": ["infographic"],
      "structure": "thesis → evidence-bands → conclusion"
    }
  ],
