{
  "id": "claude",
  "name": "Claude",
  "name_zh": "Claude",
  "description": "Claude design-language editorial system with paper warmth, Instrument Serif hierarchy, stone neutrals, fine rules, and structured content components.",
  "content_width": 720,
  "philosophy": {
    "mood": "calm-intelligent",
    "density": "balanced",
    "rhythm": "measured",
    "hierarchy": "editorial"
  },
  "constraints": {
    "accent_color_count": 1,
    "highlight_frequency_max": 0.08,
    "component_variants_max": 3,
    "forbidden": ["heavy decoration", "strong color blocks", "deep shadow", "marketing-style hero", "rounded card stacks", "bright accent colors", "dense colored callouts"]
  },
  "art_direction": {
    "article_type": "design-language-editorial",
    "spacing_scale": 1.0,
    "emphasis_mode": "quiet",
    "visual_density": "medium",
    "section_rhythm": "ruled-editorial"
  },
  "body": {
    "background": "#f7f5f2",
    "padding": "32px 24px 48px 24px"
  },
  "fonts": {
    "cjk": "'Instrument Serif', 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, 'Times New Roman', 'Songti SC', 'STSong', serif",
    "latin": "'Inter', 'Helvetica Neue', Arial, 'PingFang SC', sans-serif",
    "mono": "'SFMono-Regular', Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace"
  },
  "colors": {
    "ink": "#1d1d1b",
    "text": "#4f4f4a",
    "muted": "#6f6e68",
    "soft": "#a8a29b",
    "line": "#d8d2ca",
    "line_soft": "#e6e0d7",
    "surface": "#f7f5f2",
    "surface_alt": "#efede7",
    "accent": "#a8a29b",
    "warning": "#8f6a3e",
    "warning_bg": "#f2eee5",
    "code_text": "#2b2a27"
  },
  "typography": {
    "brand_size": "28px",
    "title_size": "52px",
    "title_line": "1.1",
    "body_size": "16px",
    "body_line": "1.75",
    "section_num_size": "13px",
    "section_title_size": "28px",
    "subhead_size": "20px",
    "small_size": "13px",
    "code_size": "13px"
  },
  "rhythm": {
    "paragraph_gap": 24,
    "heading_top": 40,
    "heading_bottom": 24,
    "quote_breathing": 24,
    "section_break": 40
  },
  "shape": {
    "radius": "4px",
    "image_radius": "0"
  },
  "components": {
    "paragraph": { "variants": ["default", "lead", "compact"] },
    "lead": { "variants": ["calm-opening"] },
    "insight": { "variants": ["soft-surface", "sentence", "closing"] },
    "pullquote": { "variants": ["quiet"] },
    "figure": { "variants": ["captioned"] },
    "softlist": { "variants": ["clean"] },
    "closingnote": { "variants": ["quiet"] },
    "quote": { "variants": ["weak-border", "note", "warning"] },
    "summary": { "variants": ["clean", "numbered", "closing"] },
    "divider": { "variants": ["hairline", "breath", "section"] },
    "list": { "variants": ["clean", "ordered", "compact"] },
    "cta": { "variants": ["text-only", "quiet-link", "closing-note"] }
  }
}
