{
  "id": "claude",
  "name": "Claude",
  "name_zh": "Claude",
  "description": "Warm low-noise documentation system for tutorials, explanations, methodology, product notes, and technical viewpoints.",
  "content_width": 640,
  "philosophy": {
    "mood": "minimal-professional",
    "density": "medium",
    "rhythm": "calm",
    "hierarchy": "clean"
  },
  "constraints": {
    "accent_color_count": 1,
    "highlight_frequency_max": 0.08,
    "component_variants_max": 3,
    "forbidden": ["heavy decoration", "strong color blocks", "deep shadow", "marketing-style hero", "large decorative section numbers", "frequent divider lines"]
  },
  "art_direction": {
    "article_type": "explanatory-document",
    "spacing_scale": 0.98,
    "emphasis_mode": "quiet",
    "visual_density": "medium-low",
    "section_rhythm": "calm-document"
  },
  "body": {
    "background": "#faf9f5",
    "padding": "24px 16px 44px 16px"
  },
  "fonts": {
    "cjk": "'PingFang SC', 'Noto Sans CJK SC', 'Source Han Sans SC', 'Microsoft YaHei', sans-serif",
    "latin": "'Inter', 'Helvetica Neue', Arial, sans-serif",
    "mono": "'SFMono-Regular', Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace"
  },
  "colors": {
    "ink": "#141413",
    "text": "#3d3d3a",
    "muted": "#73726c",
    "soft": "#aaa79f",
    "line": "#dedcd1",
    "line_soft": "#ece9df",
    "surface": "#fffefa",
    "surface_alt": "#f3f1ea",
    "accent": "#8a5a44",
    "warning": "#9a5b29",
    "warning_bg": "#fff7ec",
    "code_text": "#242421"
  },
  "typography": {
    "title_size": "28px",
    "title_line": "1.36",
    "body_size": "16px",
    "body_line": "1.78",
    "section_num_size": "20px",
    "section_title_size": "20px",
    "small_size": "14px",
    "code_size": "14px"
  },
  "rhythm": {
    "paragraph_gap": 20,
    "heading_top": 34,
    "heading_bottom": 18,
    "quote_breathing": 24,
    "section_break": 30
  },
  "shape": {
    "radius": "8px",
    "image_radius": "6px"
  },
  "components": {
    "paragraph": { "variants": ["default", "lead", "compact"] },
    "lead": { "variants": ["calm-opening"] },
    "insight": { "variants": ["soft-surface", "sentence", "closing"] },
    "pullquote": { "variants": ["quiet"] },
    "figure": { "variants": ["captioned"] },
    "softlist": { "variants": ["clean"] },
    "closingnote": { "variants": ["quiet"] },
    "quote": { "variants": ["weak-border", "note", "warning"] },
    "summary": { "variants": ["clean", "numbered", "closing"] },
    "divider": { "variants": ["hairline", "breath", "section"] },
    "list": { "variants": ["clean", "ordered", "compact"] },
    "cta": { "variants": ["text-only", "quiet-link", "closing-note"] }
  }
}
