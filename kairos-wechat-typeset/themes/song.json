{
  "id": "song",
  "name": "Song Aesthetic",
  "name_zh": "宋式美学",
  "description": "Modern Chinese mobile editorial system built on Source Han Serif, restrained ink, compact rhythm, and Song-style warmth.",
  "content_width": 640,
  "philosophy": {
    "mood": "literary",
    "density": "airy",
    "rhythm": "mobile",
    "hierarchy": "soft"
  },
  "constraints": {
    "accent_color_count": 1,
    "highlight_frequency_max": 0.08,
    "component_variants_max": 3,
    "forbidden": ["card-heavy layout", "color CTA", "strong shadow", "multiple accent colors", "high-contrast blocks", "gradient", "large tinted backgrounds"]
  },
  "art_direction": {
    "article_type": "literary",
    "spacing_scale": 1.0,
    "emphasis_mode": "restrained",
    "visual_density": "low",
    "section_rhythm": "mobile-editorial"
  },
  "body": {
    "background": "#fbf8f2",
    "padding": "28px 18px 48px 18px"
  },
  "fonts": {
    "cjk": "'Source Han Serif SC', 'Noto Serif CJK SC', 'Songti SC', 'STSong', SimSun, serif",
    "latin": "'Baskerville', 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, 'Times New Roman', serif",
    "mono": "'SFMono-Regular', Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace"
  },
  "colors": {
    "ink": "#1f1914",
    "text": "#3f3932",
    "muted": "#80766b",
    "soft": "#c8b8a4",
    "line": "#cdbfae",
    "line_soft": "#e4d8c8",
    "surface": "#f6f0e7",
    "surface_alt": "#f1e8dc",
    "accent": "#8f3f2b",
    "warning": "#8f3f2b",
    "warning_bg": "#fbf8f2",
    "code_text": "#2f2923"
  },
  "typography": {
    "title_size": "18px",
    "title_line": "1.72",
    "body_size": "16px",
    "body_line": "2.06",
    "section_num_size": "18px",
    "section_title_size": "18px",
    "small_size": "16px",
    "code_size": "16px"
  },
  "rhythm": {
    "paragraph_gap": 22,
    "heading_top": 28,
    "heading_bottom": 18,
    "quote_breathing": 14,
    "section_break": 22
  },
  "shape": {
    "radius": "2px",
    "image_radius": "4px"
  },
  "components": {
    "paragraph": { "variants": ["default", "lead", "quiet"] },
    "insight": { "variants": ["underlined", "sentence", "closing"] },
    "quote": { "variants": ["literary", "note", "warning"] },
    "summary": { "variants": ["quiet", "numbered", "closing"] },
    "divider": { "variants": ["thin-rule", "ink-dot", "breath"] },
    "list": { "variants": ["soft-marker", "ordered", "compact"] },
    "cta": { "variants": ["text-only", "quiet-link", "closing-note"] }
  }
}
