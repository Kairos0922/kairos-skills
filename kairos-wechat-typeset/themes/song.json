{
  "id": "song",
  "name": "Song Theme",
  "name_zh": "宋式美学主题",
  "description": "Modern Chinese WeChat article theme for technical longform, methodology essays, humanities commentary, lifestyle writing, and book reviews, built on Source Han Serif, paper warmth, restrained ink, technical order, and Song-style editorial breath.",
  "suitable_for": ["技术长文", "方法论", "人文评论", "生活方式", "书评"],
  "content_width": 720,
  "philosophy": {
    "mood": "literary",
    "density": "balanced",
    "rhythm": "mobile",
    "hierarchy": "soft"
  },
  "constraints": {
    "accent_color_count": 1,
    "highlight_frequency_max": 0.08,
    "component_variants_max": 3,
    "forbidden": ["card-heavy layout", "color CTA", "strong shadow", "multiple accent colors", "high-contrast blocks", "gradient", "large tinted backgrounds"]
  },
  "art_direction": {
    "article_type": "technical-editorial",
    "spacing_scale": 0.94,
    "emphasis_mode": "restrained",
    "visual_density": "medium-low",
    "section_rhythm": "technical-editorial"
  },
  "image_direction": {
    "default_aspect_ratio": "16:9",
    "preferred_visual_types": ["concept_diagram", "atmosphere_still", "comparison_diagram"],
    "style": "minimal paper editorial imagery with warm off-white ground, ink restraint, fine line structure, low saturation, and quiet object or abstract order",
    "use_for": ["核心概念解释", "方法论结构", "人文或生活方式开场定调", "克制对比关系"],
    "avoid_for": ["短段落装饰", "技术文章里的风景化转场", "重复章节配图"],
    "forbidden": ["gradient", "strong shadow", "multi-accent palette", "decorative icon list", "ancient seal", "landscape poster", "large tinted backgrounds", "busy collage"]
  },
  "body": {
    "background": "#f7f5f0",
    "padding": "24px 24px 48px 24px"
  },
  "fonts": {
    "cjk": "'Source Han Serif SC', 'Noto Serif CJK SC', 'Songti SC', 'STSong', Georgia, serif",
    "latin": "'Baskerville', 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, 'Times New Roman', serif",
    "mono": "'SFMono-Regular', Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace"
  },
  "webfonts": {
    "cjk": {
      "family": "Noto Serif SC",
      "weight": "400",
      "url": "https://cdn.jsdelivr.net/npm/@fontsource/noto-serif-sc/index.css"
    },
    "latin": {
      "family": "Playfair Display",
      "weight": "400",
      "url": "https://cdn.jsdelivr.net/npm/@fontsource/playfair-display/index.css"
    }
  },
  "colors": {
    "ink": "#2b2b2b",
    "text": "#2b2b2b",
    "muted": "#7a7a72",
    "soft": "#a6a197",
    "line": "#d8d2c8",
    "line_soft": "#e5dfd5",
    "surface": "#f7f5f0",
    "surface_alt": "#efebe3",
    "accent": "#7a7a72",
    "warning": "#7a7a72",
    "warning_bg": "#f7f5f0",
    "code_text": "#2b2b2b"
  },
  "typography": {
    "title_size": "28px",
    "title_line": "1.6",
    "body_size": "16px",
    "body_line": "1.8",
    "section_num_size": "20px",
    "section_title_size": "25px",
    "small_size": "14px",
    "code_size": "14px"
  },
  "rhythm": {
    "paragraph_gap": 24,
    "heading_top": 32,
    "heading_bottom": 16,
    "quote_breathing": 20,
    "section_break": 24
  },
  "shape": {
    "radius": "2px",
    "image_radius": "4px"
  },
  "components": {
    "paragraph": { "variants": ["default", "lead", "quiet"] },
    "lead": { "variants": ["editorial"] },
    "pullquote": { "variants": ["literary"] },
    "figure": { "variants": ["captioned"] },
    "softlist": { "variants": ["circle"] },
    "closingnote": { "variants": ["quiet"] },
    "insight": { "variants": ["underlined", "sentence", "closing"] },
    "quote": { "variants": ["literary", "note", "warning"] },
    "summary": { "variants": ["quiet", "numbered", "closing"] },
    "divider": { "variants": ["thin-rule", "ink-dot", "breath"] },
    "list": { "variants": ["soft-marker", "ordered", "compact"] },
    "cta": { "variants": ["text-only", "quiet-link", "closing-note"] }
  }
}
