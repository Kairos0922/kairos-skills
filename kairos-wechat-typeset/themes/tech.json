{
  "id": "tech",
  "name": "Technology Theme",
  "name_zh": "科技主题",
  "description": "Mobile-first WeChat article theme for AI technology articles, engineering practice, product solutions, R&D practice, and tool tutorials, translated from the blue technology magazine reference with strong black headings, precise blue section numbers, clean sans typography, dark code blocks, light-blue info panels, fine-rule tables, and compact editorial rhythm.",
  "suitable_for": ["AI 技术文章", "工程实践", "产品方案", "研发实践", "工具教程"],
  "content_width": 640,
  "philosophy": {
    "mood": "technical",
    "density": "balanced",
    "rhythm": "mobile",
    "hierarchy": "explicit"
  },
  "constraints": {
    "accent_color_count": 1,
    "highlight_frequency_max": 0.08,
    "component_variants_max": 3,
    "forbidden": ["gradient", "strong shadow", "multi-accent palette", "decorative bokeh", "rounded pill-heavy layout", "marketing CTA", "dark full-page background"]
  },
  "art_direction": {
    "article_type": "technology-editorial",
    "spacing_scale": 0.9,
    "emphasis_mode": "precise",
    "visual_density": "medium",
    "section_rhythm": "mobile-tech"
  },
  "image_direction": {
    "default_aspect_ratio": "16:9",
    "preferred_visual_types": ["concept_diagram", "process_diagram", "comparison_diagram"],
    "style": "minimal technology editorial diagrams with white background, precise thin rules, abstract interface blocks, and a single blue accent",
    "use_for": ["系统结构", "流程机制", "产品链路", "工程对比", "抽象技术概念"],
    "avoid_for": ["泛科技氛围图", "纯装饰插画", "没有结构信息的界面拼贴"],
    "forbidden": ["gradient", "strong shadow", "multi-accent palette", "decorative bokeh", "rounded pill-heavy layout", "marketing CTA", "dark full-page background", "cyberpunk"]
  },
  "body": {
    "background": "#f8f9fa",
    "padding": "32px 24px 52px 24px"
  },
  "fonts": {
    "cjk": "-apple-system, BlinkMacSystemFont, 'PingFang SC', 'Source Han Sans SC', 'Noto Sans CJK SC', 'Helvetica Neue', sans-serif",
    "latin": "Inter, -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', Arial, sans-serif",
    "mono": "'SFMono-Regular', Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace"
  },
  "webfonts": {
    "cjk": {
      "family": "Noto Sans SC",
      "weight": "400",
      "url": "https://cdn.jsdelivr.net/npm/@fontsource/noto-sans-sc/index.css"
    },
    "latin": {
      "family": "Inter",
      "weight": "400",
      "url": "https://cdn.jsdelivr.net/npm/@fontsource/inter/index.css"
    }
  },
  "colors": {
    "ink": "#111827",
    "text": "#1f2937",
    "text_secondary": "#374151",
    "text_tertiary": "#4b5563",
    "muted": "#6b7280",
    "soft": "#9ca3af",
    "line": "#d1d5db",
    "line_soft": "#e5e7eb",
    "surface": "#ffffff",
    "surface_alt": "#f0f4ff",
    "accent": "#1e40af",
    "accent_soft": "#dbeafe",
    "accent_light": "#bfdbfe",
    "warning": "#dc2626",
    "warning_bg": "#fef2f2",
    "code_text": "#e2e8f0",
    "code_bg": "#0f172a",
    "code_muted": "#94a3b8"
  },
  "typography": {
    "title_size": "30px",
    "title_line": "1.3",
    "section_num_size": "36px",
    "section_title_size": "22px",
    "h3_size": "17px",
    "body_size": "16px",
    "body_line": "1.7",
    "compact_line": "1.2",
    "small_size": "14px",
    "caption_size": "13px",
    "code_size": "14px"
  },
  "rhythm": {
    "paragraph_gap": 18,
    "heading_top": 32,
    "heading_bottom": 18,
    "quote_breathing": 22,
    "section_break": 26
  },
  "shape": {
    "radius": "8px",
    "image_radius": "8px"
  },
  "components": {
    "paragraph": { "variants": ["default", "lead", "highlight"] },
    "lead": { "variants": ["metadata-like"] },
    "pullquote": { "variants": ["blue-rule"] },
    "figure": { "variants": ["captioned"] },
    "softlist": { "variants": ["blue-dot"] },
    "closingnote": { "variants": ["info-panel"] },
    "insight": { "variants": ["info-panel", "sentence"] },
    "quote": { "variants": ["blue-rule", "note", "warning"] },
    "summary": { "variants": ["numbered"] },
    "divider": { "variants": ["thin", "dashed", "blue-rule"] },
    "list": { "variants": ["blue-marker", "ordered", "task"] },
    "cta": { "variants": ["text-only"] }
  }
}
