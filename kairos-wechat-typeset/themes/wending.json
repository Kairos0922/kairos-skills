{
  "id": "wending",
  "name": "Wending Theme",
  "name_zh": "稳境白纸主题",
  "description": "Mobile-first WeChat article theme for self-growth, psychological order, lifestyle writing, light methodology, and slow-reading essays, based on warm white paper, heavy serif headings, quiet gray metadata, precise fine rules, dark code panels, and restrained editorial rhythm.",
  "suitable_for": ["个人成长", "心理秩序", "生活方式", "轻方法论", "慢阅读文章"],
  "content_width": 640,
  "philosophy": {
    "mood": "quiet",
    "density": "balanced",
    "rhythm": "mobile",
    "hierarchy": "precise"
  },
  "constraints": {
    "accent_color_count": 1,
    "highlight_frequency_max": 0.08,
    "component_variants_max": 3,
    "forbidden": ["gradient", "strong shadow", "color CTA", "multi-accent palette", "decorative icons", "rounded pill-heavy layout", "large tinted backgrounds"]
  },
  "art_direction": {
    "article_type": "self-growth-editorial",
    "spacing_scale": 0.92,
    "emphasis_mode": "restrained",
    "visual_density": "medium",
    "section_rhythm": "mobile-spec"
  },
  "image_direction": {
    "default_aspect_ratio": "16:9",
    "preferred_visual_types": ["atmosphere_still", "concept_diagram", "comparison_diagram"],
    "style": "quiet warm-white editorial imagery with soft natural light, grayscale order, restrained life details, and calm psychological structure",
    "use_for": ["开篇情绪定调", "心理秩序概念", "生活方式方法", "轻量对比关系"],
    "avoid_for": ["鸡汤海报", "抽象观点的重复装饰", "无信息量生活摆拍"],
    "forbidden": ["gradient", "strong shadow", "multi-accent palette", "decorative icons", "rounded pill-heavy layout", "large tinted backgrounds", "stock motivational poster", "busy collage"]
  },
  "body": {
    "background": "#fbfaf7",
    "padding": "22px 20px 42px 20px"
  },
  "fonts": {
    "cjk": "'Source Han Serif CN', 'Source Han Serif SC', 'Noto Serif CJK SC', 'Songti SC', 'STSong', Georgia, serif",
    "latin": "'Baskerville', 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, 'Times New Roman', serif",
    "mono": "'SFMono-Regular', Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace"
  },
  "webfonts": {
    "cjk": {
      "family": "Noto Serif SC",
      "weight": "400",
      "url": "https://cdn.jsdelivr.net/npm/@fontsource/noto-serif-sc/index.css"
    },
    "latin": {
      "family": "Playfair Display",
      "weight": "400",
      "url": "https://cdn.jsdelivr.net/npm/@fontsource/playfair-display/index.css"
    }
  },
  "colors": {
    "ink": "#111111",
    "text": "#333333",
    "text_secondary": "#555555",
    "text_tertiary": "#777777",
    "muted": "#888888",
    "soft": "#b7b0a4",
    "line": "#dedbd3",
    "line_soft": "#ece9e2",
    "surface": "#fbfaf7",
    "surface_alt": "#f4f3f1",
    "accent": "#a89f90",
    "accent_light": "#d4cec3",
    "warning": "#111111",
    "warning_bg": "#f4f3f1",
    "code_text": "#e8e4dc",
    "code_bg": "#1f2227",
    "code_muted": "#9ca1aa"
  },
  "typography": {
    "title_size": "30px",
    "title_line": "1.35",
    "section_num_size": "42px",
    "section_title_size": "22px",
    "h3_size": "17px",
    "body_size": "16px",
    "body_line": "1.7",
    "compact_line": "1.2",
    "small_size": "14px",
    "code_size": "14px"
  },
  "rhythm": {
    "paragraph_gap": 20,
    "heading_top": 34,
    "heading_bottom": 18,
    "quote_breathing": 22,
    "section_break": 28
  },
  "shape": {
    "radius": "2px",
    "image_radius": "8px"
  },
  "components": {
    "paragraph": { "variants": ["default", "lead", "quiet"] },
    "lead": { "variants": ["opening"] },
    "pullquote": { "variants": ["paper-quote"] },
    "figure": { "variants": ["captioned"] },
    "softlist": { "variants": ["plain"] },
    "closingnote": { "variants": ["quiet"] },
    "insight": { "variants": ["soft-panel", "sentence"] },
    "quote": { "variants": ["paper", "note", "warning"] },
    "summary": { "variants": ["plain", "numbered"] },
    "divider": { "variants": ["thin-rule"] },
    "list": { "variants": ["plain", "ordered", "task"] },
    "cta": { "variants": ["text-only"] }
  }
}
