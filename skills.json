{
  "schema_version": 1,
  "repository": "kairos-skills",
  "purpose": "Personal reusable skill collection for AI coding agents.",
  "skills": [
    {
      "id": "skill-autoresearch",
      "path": "skill-autoresearch",
      "status": "runnable",
      "summary": "Automatically optimize agent skills through edit, eval, and keep/revert loops.",
      "entrypoints": [
        "SKILL.md",
        "scripts/loop.py"
      ],
      "validation": [
        "python3 -m py_compile scripts/loop.py scripts/harness.py scripts/aggregate.py scripts/decision.py scripts/watchdog.py"
      ]
    },
    {
      "id": "kairos-wechat-typeset",
      "path": "kairos-wechat-typeset",
      "status": "runnable",
      "summary": "Deterministic Markdown-to-WeChat semantic editorial component system.",
      "entrypoints": [
        "SKILL.md",
        "scripts/typeset.py",
        "scripts/render.py",
        "scripts/verify.py",
        "scripts/verify_markdown.py",
        "scripts/audit_visual.py"
      ],
      "validation": [
        "python3 scripts/render.py --list-themes",
        "python3 scripts/typeset.py --check",
        "python3 scripts/verify.py --input goldens/song-style.html",
        "python3 scripts/audit_visual.py --input goldens/song-style.html --allowed-font-size 16px --allowed-font-size 18px --max-margin-px 44",
        "python3 scripts/verify.py --input goldens/mimo-style.html",
        "python3 scripts/verify.py --input goldens/claude-style.html"
      ]
    }
  ]
}
