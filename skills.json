        "scripts/verify_design_system.py"
      ],
      "validation": [
        "PYTHONPYCACHEPREFIX=.pycache python3 -m py_compile shared/*.py",
        "PYTHONPYCACHEPREFIX=.pycache python3 -m py_compile scripts/*.py",
