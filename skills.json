{
  "schema_version": 1,
  "repository": "kairos-skills",
  "purpose": "开源 AI 内容生产 Skill 集合。确定性脚本 + 主题契约 + 验证规则，让 AI agent 输出稳定、高级、可重复的内容产物。",
  "skills": [
    {
      "id": "kairos-wechat-typeset",
      "path": "kairos-wechat-typeset",
      "status": "runnable",
      "version": "1.1.0",
      "summary": "Markdown 文章 → 微信公众号可粘贴的 inline HTML。5 套主题（song / wending / tech / wisme / pi），语义组件系统 + 主题视觉哲学，确定性渲染管线。",
      "entrypoints": [
        "SKILL.md",
        "CHEATSHEET.md",
        "PRODUCT.md",
        "COMPONENTS.md",
        "DESIGN.md",
        "themes/registry.json",
        "themes/METHODOLOGY.md",
        "semantic/analyze.py",
        "renderer/blocks.py",
        "renderer/compiler.py",
        "renderer/variants.py",
        "scripts/render.py",
        "scripts/typeset.py",
        "scripts/check_all.py"
      ],
      "validation": [
        "PYTHONPYCACHEPREFIX=.pycache python3 -m py_compile scripts/render.py",
        "PYTHONPYCACHEPREFIX=.pycache python3 -m py_compile scripts/typeset.py",
        "python3 -m json.tool themes/registry.json",
        "python3 scripts/render.py --list-themes",
        "python3 scripts/typeset.py --check",
        "python3 scripts/verify_image_plan.py --input fixtures/image-plan.sample.json --theme tech"
      ]
    },
    {
